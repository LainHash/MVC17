@using MVC17.Helpers.Constants.Globals
@{
    var jwt = Context.Request.Cookies["jwt"];

    var username = User.Identity?.IsAuthenticated == true
        ? User.Identity.Name
        : null;

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}


<!-- Navbar & Hero Start -->
<div class="container-fluid nav-bar sticky-top px-0 px-lg-4 py-2 py-lg-0">
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-light">
            <a href="" class="navbar-brand p-0">
                <h1 class="display-6 text-primary"><i class="fas fa-car-alt me-3"></i>TechStore</h1>
                <!-- <img src="img/logo.png" alt="Logo"> -->
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="fa fa-bars"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <div class="navbar-nav mx-auto py-0">
                    <a class="nav-item nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="Index">
                        <i class="fas fa-home fa-lg"></i>
                        @RouteDisplayName.HomePage
                    </a>
                    @await Component.InvokeAsync("CategoryMenu")
                    <a class="nav-item nav-link @(currentController == "Cart" && currentAction == "Index" ? "active" : "")"
                           asp-controller="Cart"
                           asp-action="Index">
                        <i class="fas fa-shopping-cart fa-lg"></i>
                        @RouteDisplayName.ShoppingCartPage
                    </a>
                    
                </div>
                @if (username != null)
                {
                    <div class="dropdown">
                        <a class="btn btn-primary rounded-pill py-2 px-4"
                               asp-area=""
                               asp-controller="Account"
                               asp-action="Profile">
                            Xin chào, @username
                            <i class="fas fa-user fa-lg"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item d-flex justify-content-between align-items-center"
                                       asp-area=""
                                       asp-controller="Account"
                                       asp-action="OrderHistory">
                                    @RouteDisplayName.OrderHistory
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex justify-content-between align-items-center"
                                       asp-area=""
                                       asp-controller="Account"
                                       asp-action="Logout">
                                    @RouteDisplayName.LogoutPage
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="btn btn-primary rounded-pill py-2 px-4"
                           asp-area=""
                           asp-controller="Account"
                           asp-action="Login">
                        @RouteDisplayName.LoginPage
                    </a>
                }
            </div>
        </nav>
    </div>
</div>
<!-- Navbar & Hero End -->