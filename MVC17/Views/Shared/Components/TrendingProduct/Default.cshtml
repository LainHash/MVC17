@model IEnumerable<MVC17.ViewModels.TrendingLaptopVM>

<!-- Car categories Start -->
<div class="container-fluid categories py-5">
    <div class="container">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 800px;">
            <h1 class="display-5 text-capitalize mb-3">Laptop <span class="text-primary">Xu hướng</span></h1>
            <p class="mb-0">
                nơi hiệu năng mạnh mẽ gặp thiết kế mỏng nhẹ, AI thông minh và thời lượng pin bền bỉ, sẵn sàng cho học tập, làm việc lẫn giải trí mọi lúc.
            </p>
        </div>
        <div class="categories-carousel owl-carousel wow fadeInUp" data-wow-delay="0.1s">
            @foreach (var item in Model)
            {
                <div class="categories-item p-4">
                    <div class="categories-item-inner">
                        <div class="categories-img rounded-top">
                            <img src="@item.ImageUrl" class="img-fluid w-100 rounded-top" alt="">
                        </div>
                        <div class="categories-content rounded-bottom p-4">
                            <h4>@item.ProductName</h4>
                            <div class="categories-review mb-4">
                                <div class="me-3">@item.UnitsInStock</div>
                                <div class="d-flex justify-content-center text-secondary">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star text-body"></i>
                                </div>
                            </div>
                            <div class="mb-4">
                                <h4 class="bg-white text-primary rounded-pill py-2 px-4 mb-0">@Html.DisplayFor(modeItem => item.UnitPrice)</h4>
                            </div>
                            <div class="row gy-2 gx-0 text-center mb-4">
                                <div class="col-4 border-end border-white">
                                    Loại Laptop: <span class="text-body ms-1">@item.LaptopType</span>
                                </div>
                                <div class="col-4 border-end border-white">
                                    <span class="text-body ms-1">@item.CpuName</span>
                                </div>
                                <div class="col-4 border-end border-white">
                                    <span class="text-body ms-1">@item.GpuName</span>
                                </div>
                                <div class="col-4">
                                    <span class="text-body ms-1">@item.RamName</span>
                                </div>
                                <div class="col-4 border-end border-white">
                                    <span class="text-body ms-1">@item.StorageName</span>
                                </div>
                            </div>
                            <a class="nav-item nav-link" asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">Chi tiết</a>
                        </div>
                    </div>
                </div>
            }
       
        </div>
    </div>
</div>
<!-- Car categories End -->