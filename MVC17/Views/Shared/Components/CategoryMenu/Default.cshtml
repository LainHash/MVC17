@using MVC17.Helpers.Constants.Globals
@model IEnumerable<MVC17.ViewModels.CategoryMenuVM>

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<div class="dropdown">

    <a class="nav-item nav-link @(currentController == "Product" && currentAction == "Index" ? "active" : "")"
           asp-area=""
           asp-controller="Product"
           asp-action="Index">
        <i class="fas fa-box fa-lg"></i>
        @RouteDisplayName.ProductsPage
    </a>

    <ul class="dropdown-menu">
        @foreach (var item in Model)
        {
            <li>
                <a class="dropdown-item d-flex justify-content-between align-items-center"
                       asp-controller="Product"
                       asp-action="Index"
                       asp-route-categoryId="@item.CategoryId">

                    <span>@item.Name</span>
                    <span class="badge bg-primary rounded-pill">@item.Count</span>
                </a>
            </li>
        }
    </ul>
</div>
