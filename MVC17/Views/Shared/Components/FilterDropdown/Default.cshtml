@model MVC17.ViewModels.FilterDropdownVM

@{
    var currentItem = Model.Items.FirstOrDefault(i => i.Value == Model.CurrentValue);
    var currentName = currentItem != null ? currentItem.Text : Model.DefaultText;
    var btnId = "btn" + Model.Name;
}

<div class="col-12 col-md-3">
    <div class="input-group shadow-sm">
        <span class="input-group-text bg-white border-end-0 text-muted"
              style="border-top-left-radius: 50rem; border-bottom-left-radius: 50rem;">
            <i class="@Model.IconClass"></i>
        </span>
        <div class="dropdown flex-grow-1">
            <button class="form-select border-start-0 shadow-none fw-medium text-dark bg-transparent text-start w-100"
                    style="border-top-right-radius: 50rem; border-bottom-right-radius: 50rem;"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false" id="@btnId">
                @currentName
            </button>
            <ul class="dropdown-menu w-100 shadow-sm border-0 mt-1 py-2"
                style="max-height: 300px; overflow-y: auto;">
                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center custom-dropdown-item py-2"
                           href="#" data-val="0"
                           data-text="@Model.DefaultText"
                           data-target="@Model.Name"
                           data-display="@btnId">
                        <span class="@((Model.CurrentValue == "0" || string.IsNullOrEmpty(Model.CurrentValue)) ? "fw-bold text-primary" : "")">@Model.DefaultText</span>
                    </a>
                </li>
                @foreach (var item in Model.Items)
                {
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center custom-dropdown-item py-2"
                               href="#"
                               data-val="@item.Value"
                               data-text="@item.Text"
                               data-target="@Model.Name"
                               data-display="@btnId">
                            <span class="@(item.Value == Model.CurrentValue ? "fw-bold text-primary" : "")">@item.Text</span>
                            @if (Model.ShowBadge && item.Count.HasValue)
                            {
                                <span class="badge @(item.Value == Model.CurrentValue ? "bg-primary" : "bg-light text-dark") rounded-pill">@item.Count</span>
                            }
                        </a>
                    </li>
                }
            </ul>
            <input type="hidden" name="@Model.Name" id="@Model.Name" value="@Model.CurrentValue" />
        </div>
    </div>
</div>
