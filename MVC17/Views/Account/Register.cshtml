@model MVC17.DTOs.Accounts.Create.RegisterDTO


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header text-center">
                    <h3>Đăng ký</h3>
                </div>

                <div class="card-body">
                    <form asp-action="Register" method="post">

                        
                        <div class="row">
                            <!-- Username -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Username" class="form-label"></label>
                                <input asp-for="Username" class="form-control" />
                            </div>

                            <!-- Email -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <!-- Password -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" type="password" class="form-control" />
                            </div>

                            <!-- Confirm Password -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <!-- First Name -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Profile.FirstName" class="form-label"></label>
                                <input asp-for="Profile.FirstName" class="form-control" />
                            </div>

                            <!-- Last Name -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Profile.LastName" class="form-label"></label>
                                <input asp-for="Profile.LastName" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <!-- Gender -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="Profile.Gender" class="form-select">
                                    <option value="true">Male</option>
                                    <option value="false">Female</option>
                                </select>
                            </div>

                            <!-- Dob -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Profile.Dob" class="form-label"></label>
                                <input asp-for="Profile.Dob" type="date" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <!-- City -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Profile.City" class="form-label"></label>
                                <select asp-for="Profile.City" class="form-select" asp-items="ViewBag.Cities"></select>
                            </div>

                            <!-- Country -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Profile.Country" class="form-label"></label>
                                <select asp-for="Profile.Country" class="form-select" asp-items="ViewBag.Countries"></select>
                            </div>
                        </div>

                        <!-- Address -->
                        <div class="mb-3">
                            <label asp-for="Profile.Address" class="form-label"></label>
                            <input asp-for="Profile.Address" class="form-control" />
                        </div>

                        <div class="row">
                            <!-- Personal Email -->
                            <div class="mb-3">
                                <label asp-for="Profile.Email" class="form-label"></label>
                                <input asp-for="Profile.Email" class="form-control" />
                            </div>

                            <!-- Phone -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Profile.Phone" class="form-label"></label>
                                <input asp-for="Profile.Phone" class="form-control" />
                            </div>
                        </div>

                        
                        <!-- CCCD -->
                        <div class="mb-3">
                            <label asp-for="Profile.CitizenIdentityCard" class="form-label"></label>
                            <input asp-for="Profile.CitizenIdentityCard" class="form-control" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                Đăng ký
                            </button>
                        </div>

                    </form>
                </div>

                <div class="card-footer text-center">
                    <small>Đã có tài khoản? <a asp-action="Login">Đăng nhập</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}