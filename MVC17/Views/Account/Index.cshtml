@model IEnumerable<MVC17.Models.User>

@{
    ViewData["Title"] = "Quản lý Tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark"><i class="fas fa-users-cog me-2 text-primary"></i> Danh sách Tài khoản</h2>
            <p class="text-muted mb-0">Quản lý người dùng, phân quyền và trạng thái hoạt động</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4 fw-semibold border-bottom-0">
                                ID
                            </th>
                            <th class="fw-semibold border-bottom-0">
                                Email
                            </th>
                            <th class="fw-semibold border-bottom-0">
                                Tên người dùng
                            </th>
                            <th class="fw-semibold border-bottom-0">
                                Vai trò
                            </th>
                            <th class="fw-semibold border-bottom-0">
                                Trạng thái
                            </th>
                            <th class="pe-4 fw-semibold border-bottom-0 text-center">
                                Thao tác
                            </th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.UserId</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">@item.Email</h6>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.Username</td>
                                <td>
                                    @if (item.RoleId == 1)
                                    {
                                        <span class="badge bg-secondary px-3 py-2 rounded-pill">Khách hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary px-3 py-2 rounded-pill">Quản lý</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="text-success"><i class="fas fa-check-circle me-1"></i>Đã xác nhận</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning"><i class="fas fa-exclamation-circle me-1"></i>Chưa xác nhận</span>
                                    }
                                </td>
                                <td class="pe-4 text-center">
                                    <button class="btn btn-sm btn-outline-secondary" disabled title="Tính năng đang phát triển">
                                        <i class="fas fa-cog"></i>
                                    </button>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-users fa-3x mb-3 text-light"></i>
                                    <p class="mb-0">Chưa có tài khoản nào trong hệ thống.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">Hiển thị tổng số <span class="fw-bold">@Model.Count()</span> tài khoản</small>
            </div>
        </div>
    </div>
</div>
