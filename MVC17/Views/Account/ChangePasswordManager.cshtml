@model MVC17.DTOs.Accounts.Update.ChangePasswordDTO

@{
    ViewData["Title"] = "Đổi Mật Khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark">
                <i class="fas fa-key me-2 text-warning"></i>Đổi Mật Khẩu
            </h2>
            <p class="text-muted mb-0">Cập nhật mật khẩu của tài khoản nhân viên</p>
        </div>
        <a asp-action="ProfileManager" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay Lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <form asp-action="ChangePasswordManager" method="post">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 py-2">
                            <i class="fas fa-lock text-primary me-2"></i>Thay Đổi Mật Khẩu
                        </h5>
                    </div>
                    <div class="card-body">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Old Password -->
                        <div class="mb-4">
                            <label asp-for="OldPassword" class="form-label fw-bold">Mật Khẩu Hiện Tại</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-lock text-muted"></i>
                                </span>
                                <input asp-for="OldPassword" type="password" class="form-control border-start-0" placeholder="Nhập mật khẩu hiện tại" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="OldPassword" class="text-danger small d-block mt-1"></span>
                        </div>

                        <!-- New Password -->
                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-bold">Mật Khẩu Mới</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-key text-muted"></i>
                                </span>
                                <input asp-for="NewPassword" type="password" class="form-control border-start-0" placeholder="Nhập mật khẩu mới" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small d-block mt-1"></span>
                            <small class="text-muted d-block mt-2">
                                <i class="fas fa-info-circle"></i> Mật khẩu phải có ít nhất 6 ký tự
                            </small>
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-bold">Xác Nhận Mật Khẩu Mới</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-check-circle text-muted"></i>
                                </span>
                                <input asp-for="ConfirmNewPassword" type="password" class="form-control border-start-0" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small d-block mt-1"></span>
                        </div>

                        <!-- Info Alert -->
                        <div class="alert alert-info mb-4" role="alert">
                            <i class="fas fa-lightbulb me-2"></i>
                            <strong>Lưu ý:</strong> Sau khi đổi mật khẩu, bạn sẽ cần đăng nhập lại với mật khẩu mới.
                        </div>
                    </div>

                    <div class="card-footer bg-white border-top">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-save me-2"></i>Cập Nhật Mật Khẩu
                            </button>
                        </div>
                        <div class="d-grid gap-2 mt-2">
                            <a asp-action="ProfileManager" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Hủy
                            </a>
                        </div>
                    </div>
                </div>
            </form>

            <!-- Security Tips -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0 py-2">
                        <i class="fas fa-shield-alt text-success me-2"></i>Mẹo Bảo Mật
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="mb-0 small">
                        <li class="mb-2">
                            <strong>Sử dụng mật khẩu mạnh:</strong> Kết hợp chữ hoa, chữ thường, số và ký tự đặc biệt
                        </li>
                        <li class="mb-2">
                            <strong>Không chia sẻ mật khẩu:</strong> Không bao giờ chia sẻ mật khẩu của bạn với ai
                        </li>
                        <li class="mb-2">
                            <strong>Cập nhật định kỳ:</strong> Thay đổi mật khẩu của bạn định kỳ (ít nhất mỗi 3 tháng)
                        </li>
                        <li>
                            <strong>Đăng xuất khi kết thúc:</strong> Luôn đăng xuất khi bạn kết thúc phiên làm việc
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
