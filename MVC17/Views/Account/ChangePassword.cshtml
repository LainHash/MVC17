@model MVC17.DTOs.Accounts.Update.ChangePasswordDTO

@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_Layout";
}



<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="pwd-card">
            <h2 class="pwd-header"><i class="fas fa-lock me-2"></i>Đổi mật khẩu</h2>
            
            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="OldPassword" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-key text-muted"></i></span>
                        <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                    </div>
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-lock text-muted"></i></span>
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu mới" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmNewPassword" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-check-circle text-muted"></i></span>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu mới" />
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-black"><i class="fas fa-save me-2"></i>Cập nhật mật khẩu</button>
                
                <a asp-action="Edit" class="back-link"><i class="fas fa-arrow-left me-1"></i> Quay lại trang chỉnh sửa</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}