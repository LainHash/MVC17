@model IEnumerable<MVC17.ViewModels.OrderHistoryVM>

@{
    ViewData["Title"] = "Lịch sử đặt hàng";
}

<div class="container mt-5 mb-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="mb-0"><i class="fas fa-history text-primary me-2"></i>Lịch sử đặt hàng</h2>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Tiếp tục mua sắm
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm d-flex align-items-center" role="alert">
            <i class="fas fa-info-circle fs-4 me-3"></i>
            <div>
                Bạn chưa có đơn hàng nào. Hãy khám phá các sản phẩm của chúng tôi nhé!
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th scope="col" class="py-3 ps-4">Mã đơn hàng</th>
                                <th scope="col" class="py-3">Ngày đặt</th>
                                <th scope="col" class="py-3 text-end">Tổng tiền</th>
                                <th scope="col" class="py-3 text-center">Trạng thái</th>
                                <th scope="col" class="py-3 pe-4 text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold">#@item.InvoiceId</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="far fa-calendar-alt text-muted me-2"></i>
                                            @item.OrderedDate.ToString("dd/MM/yyyy")
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @item.TotalAmount.ToString("N0") đ
                                    </td>
                                    <td class="text-center">
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="fas fa-clock me-1"></i> Chờ xử lý</span>
                                        }
                                        else if (item.Status == "Completed" || item.Status == "Delivered")
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fas fa-check-circle me-1"></i> Hoàn thành</span>
                                        }
                                        else if (item.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fas fa-times-circle me-1"></i> Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Status</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-center">
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@item.InvoiceId" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye me-1"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>