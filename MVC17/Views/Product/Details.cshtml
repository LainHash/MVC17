<!-- Product Details Section -->
<div class="container-fluid product-details-section py-5">
    <div class="container">
        <!-- Header Navigation -->
        <div class="row mb-5">
            <div class="col-12">
                <div class="d-flex align-items-center mb-4">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="display-5 mb-2">
                            <i class="fas fa-search-plus text-info me-3"></i>Chi tiết sản phẩm
                        </h1>
                        <p class="text-secondary">Thông tin đầy đủ về sản phẩm</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Product Image & Basic Info -->
            <div class="col-lg-5">
                <div class="details-card product-image-card h-100">
                    <div class="product-image-container">
                        <img src="@(Model.ImageUrl ?? "~/img/NotFoundImage.png")"
                             alt="@Model.ProductName"
                             class="img-fluid rounded w-100"
                             style="aspect-ratio: 1 / 1; object-fit: cover;" />
                    </div>
                    
                    <!-- Quick Status -->
                    <div class="mt-4">
                        <div class="d-flex gap-2 mb-3">
                            <span class="badge @(Model.UnitsInStock > 0 ? "bg-success" : "bg-danger") px-3 py-2 fs-6">
                                @if(Model.UnitsInStock > 0)
                                {
                                    <i class="fas fa-check-circle me-2"></i>
                                    <span>Còn hàng(@Model.UnitsInStock)</span>
                                }
                                else
                                {
                                    
                                    <i class="fas fa-ban me-2"></i><span>Hết hàng</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Information -->
            <div class="col-lg-7">
                <div class="details-card h-100">
                    <!-- Title & Price -->
                    <div class="details-header pb-4 border-bottom">
                        <h2 class="product-detail-title mb-3">@Model.ProductName</h2>
                        <div class="d-flex align-items-baseline gap-3 mb-4">
                            <h3 class="price-display text-primary fw-bold">
                                @Model.UnitPrice.ToString("N0") 
                                <span class="text-secondary" style="font-size: 0.8em;">đ</span>
                            </h3>
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>Giá hiện tại
                            </small>
                        </div>
                    </div>

                    <!-- Details Grid -->
                    <div class="details-grid mt-4">
                        <!-- Basic Info -->
                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-barcode text-primary me-2"></i>Mã sản phẩm
                            </div>
                            <div class="detail-value">
                                <code>@Model.ProductUuid</code>
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-tag text-info me-2"></i>Loại sản phẩm
                            </div>
                            <div class="detail-value">
                                <span class="badge bg-info-light text-info px-3 py-2">@Model.CategoryName</span>
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-building text-warning me-2"></i>Nhà cung cấp
                            </div>
                            <div class="detail-value">
                                @Model.CompanyName
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-cubes text-success me-2"></i>Số lượng kho
                            </div>
                            <div class="detail-value">
                                <strong>@Model.UnitsInStock</strong> sản phẩm
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-calendar text-secondary me-2"></i>Ngày tạo
                            </div>
                            <div class="detail-value">
                                @(Model.CreatedAt.ToString("dd/MM/yyyy HH:mm") ?? "Không có")
                            </div>
                        </div>

                        <!-- Description -->
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="detail-row full-width mt-4 pt-4 border-top">
                                <div class="detail-label mb-3">
                                    <i class="fas fa-file-alt text-primary me-2"></i>Mô tả chi tiết
                                </div>
                                <div class="detail-value description-text">
                                    @Html.Raw(Model.Description)
                                </div>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>

        <!-- Technical Specifications Section -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="specifications-header mb-4">
                    <h3 class="mb-0">
                        <i class="fas fa-cogs text-primary me-2"></i>Thông số kỹ thuật chi tiết
                    </h3>
                    <p class="text-secondary small mt-2">Thông tin chi tiết về từng thành phần của sản phẩm</p>
                </div>
                @await Component.InvokeAsync("ProductSpec", Model)
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="details-actions pt-4 border-top">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <a asp-action="Edit" asp-route-id="@Model.ProductId"
                               class="btn btn-primary btn-lg w-100 rounded-pill">
                                <i class="fas fa-edit me-2"></i>Chỉnh sửa
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-action="Delete" asp-route-id="@Model.ProductId"
                               class="btn btn-danger btn-lg w-100 rounded-pill">
                                <i class="fas fa-trash me-2"></i>Xóa
                            </a>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 rounded-pill">
                                <i class="fas fa-list me-2"></i>Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
