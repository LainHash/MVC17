@model MVC17.ViewModels.ProductVM

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using System.Security.Claims
@{
    var roleClaim = User.FindFirstValue(ClaimTypes.Role);
    bool isManager = User.Identity?.IsAuthenticated == true && roleClaim != "1";
}

<!-- Product Details Section -->
<div class="container-fluid product-details-section py-5">
    <div class="container">
        <!-- Header Navigation -->
        <div class="row mb-5">
            <div class="col-12">
                <div class="d-flex align-items-center mb-4">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="display-5 mb-2">
                            <i class="fas fa-search-plus text-info me-3"></i>Chi tiết sản phẩm
                        </h1>
                        <p class="text-secondary">Thông tin đầy đủ về sản phẩm</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Product Image & Basic Info -->
            <div class="col-lg-5">
                <div class="details-card product-image-card h-100">
                    <div class="product-image-container">
                        <img src="@(Model.ImageUrl ?? "~/img/NotFoundImage.png")"
                             alt="@Model.ProductName"
                             class="img-fluid rounded w-100"
                             style="aspect-ratio: 1 / 1; object-fit: cover;" />
                    </div>
                    
                    <!-- Quick Status -->
                    <div class="mt-4">
                        <div class="d-flex gap-2 mb-3">
                            <span class="badge @(Model.UnitsInStock > 0 ? "bg-success" : "bg-danger") px-3 py-2 fs-6">
                                @if (Model.UnitsInStock > 0)
                                {
                                    <i class="fas fa-check-circle me-2"></i>
                                    <span>Còn hàng(@Model.UnitsInStock)</span>
                                }
                                else
                                {
                                    
                                    <i class="fas fa-ban me-2"></i><span>Hết hàng</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Information -->
            <div class="col-lg-7">
                <div class="details-card h-100">
                    <!-- Title & Price -->
                    <div class="details-header pb-4 border-bottom">
                        <h2 class="product-detail-title mb-3">@Model.ProductName</h2>
                        <div class="d-flex align-items-baseline gap-3 mb-4">
                            <h3 class="price-display text-primary fw-bold">
                                @Model.UnitPrice.ToString("N0")
                                <span class="text-secondary" style="font-size: 0.8em;">đ</span>
                            </h3>
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>Giá hiện tại
                            </small>
                        </div>
                    </div>

                    <!-- Details Grid -->
                    <div class="details-grid mt-4">
                        <!-- Basic Info -->
                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-barcode text-primary me-2"></i>Mã sản phẩm
                            </div>
                            <div class="detail-value">
                                <code>@Model.ProductUuid</code>
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-tag text-info me-2"></i>Loại sản phẩm
                            </div>
                            <div class="detail-value">
                                <span class="badge bg-info-light text-info px-3 py-2">@Model.CategoryName</span>
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-building text-warning me-2"></i>Nhà cung cấp
                            </div>
                            <div class="detail-value">
                                @Model.CompanyName
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-cubes text-success me-2"></i>Số lượng kho
                            </div>
                            <div class="detail-value">
                                <strong>@Model.UnitsInStock</strong> sản phẩm
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="detail-label">
                                <i class="fas fa-calendar text-secondary me-2"></i>Ngày tạo
                            </div>
                            <div class="detail-value">
                                @(Model.CreatedAt.ToString("dd/MM/yyyy HH:mm") ?? "Không có")
                            </div>
                        </div>

                        <!-- Description -->
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="detail-row full-width mt-4 pt-4 border-top">
                                <div class="detail-label mb-3">
                                    <i class="fas fa-file-alt text-primary me-2"></i>Mô tả chi tiết
                                </div>
                                <div class="detail-value description-text">
                                    @Html.Raw(Model.Description)
                                </div>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>

        <!-- Technical Specifications Section -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="specifications-header mb-4">
                    <h3 class="mb-0">
                        <i class="fas fa-cogs text-primary me-2"></i>Thông số kỹ thuật chi tiết
                    </h3>
                    <p class="text-secondary small mt-2">Thông tin chi tiết về từng thành phần của sản phẩm</p>
                </div>
                @await Component.InvokeAsync("ProductSpec", Model)
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="details-actions pt-4 border-top">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <a asp-controller="Order"
                                   asp-action="Checkout"
                                   asp-route-productId="@Model.ProductId"
                                   class="btn btn-primary btn-lg w-100 rounded-pill">
                                Mua ngay
                            </a>
                        </div>
                        <div class="col-md-6">
                            <form asp-controller="Cart"
                                  asp-action="Add"
                                  method="post"
                                  class="add-to-cart-form d-inline">
                                <input type="hidden" name="id" value="@Model.ProductId" />
                                <input type="hidden" name="quantity" value="1" />

                                <button type="submit"
                                        class="btn btn-outline-primary btn-sm"
                                        title="Thêm vào giỏ hàng">
                                    Thêm vào giỏ hàng
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 rounded-pill">
                                <i class="fas fa-list me-2"></i>Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="reviews-header mb-4">
                    <h3 class="mb-0">
                        <i class="fas fa-comments text-primary me-2"></i>Đánh giá sản phẩm
                    </h3>
                    <p class="text-secondary small mt-2">Nhận xét từ khách hàng và phản hồi</p>
                </div>

                @if (User.Identity?.IsAuthenticated == true && !isManager)
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <h5 class="card-title mb-3">Viết đánh giá của bạn</h5>
                            <form asp-controller="Review" asp-action="AddReview" method="post">
                                <input type="hidden" name="productId" value="@Model.ProductId" />
                                <div class="mb-3">
                                    <label class="form-label">Đánh giá sao</label>
                                    <select name="rating" class="form-select w-auto" required>
                                        <option value="5">5 Sao - Tuyệt vời</option>
                                        <option value="4">4 Sao - Rất tốt</option>
                                        <option value="3">3 Sao - Bình thường</option>
                                        <option value="2">2 Sao - Kém</option>
                                        <option value="1">1 Sao - Rất kém</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Tiêu đề</label>
                                    <input type="text" name="title" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Nội dung đánh giá</label>
                                    <textarea name="comment" class="form-control" rows="3" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                            </form>
                        </div>
                    </div>
                }

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    <div class="review-list">
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="card shadow-sm mb-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div>
                                            <strong class="text-primary">@(review.User?.Username)</strong>
                                            <span class="text-muted ms-2 small">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                        <div>
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <i class="fas fa-star @(i < review.Rating ? "text-warning" : "text-muted")"></i>
                                            }
                                        </div>
                                    </div>
                                    <h6 class="fw-bold">@review.Title</h6>
                                    <p class="mb-2">@review.Comment</p>

                                    @if (review.ProductReviewReplies != null && review.ProductReviewReplies.Any())
                                    {
                                        <div class="mt-3 ms-4 ps-3 border-start border-2 border-primary bg-light p-2 rounded">
                                            @foreach (var reply in review.ProductReviewReplies)
                                            {
                                                <div class="mb-2">
                                                    <strong class="text-info"><i class="fas fa-user-tie me-1"></i> Quản trị viên (@(reply.Employee?.User?.Username))</strong>
                                                    <span class="text-muted ms-2 small">@(reply.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</span>
                                                    <p class="mb-0 mt-1">@reply.ReplyContent</p>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (User.Identity?.IsAuthenticated == true && isManager)
                                    {
                                        <div class="mt-3">
                                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#replyForm-@review.ReviewId">
                                                <i class="fas fa-reply me-1"></i> Phản hồi
                                            </button>
                                            <div class="collapse mt-2" id="replyForm-@review.ReviewId">
                                                <form asp-controller="Review" asp-action="AddReply" method="post">
                                                    <input type="hidden" name="reviewId" value="@review.ReviewId" />
                                                    <div class="input-group">
                                                        <textarea name="replyContent" class="form-control" rows="2" placeholder="Nhập phản hồi..." required></textarea>
                                                        <button class="btn btn-primary" type="submit">Gửi</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        Chưa có đánh giá nào cho sản phẩm này.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<partial name="_CartModal" />