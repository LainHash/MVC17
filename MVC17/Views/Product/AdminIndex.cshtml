@model List<MVC17.ViewModels.ProductVM>

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark"><i class="fas fa-boxes me-2 text-primary"></i>Danh sách Sản phẩm</h2>
            <p class="text-muted mb-0">Quản lý kho hàng và thông tin sản phẩm</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary shadow-sm btn-action-modal" data-title="Thêm mới Sản phẩm">
                <i class="fas fa-plus me-1"></i> Thêm mới
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-4 border-0" style="background: linear-gradient(to right, #f8f9fa, #ffffff);">
        <div class="card-body p-4">
            <form asp-action="AdminIndex" method="get" id="filter-form">
                <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-3">
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white border-end-0 text-muted" style="border-top-left-radius: 50rem; border-bottom-left-radius: 50rem;"><i class="fas fa-search"></i></span>
                            <input type="text"
                                   name="filterString"
                                   value="@ViewData["CurrentFilter"]"
                                   class="form-control border-start-0 ps-0 shadow-none"
                                   style="border-top-right-radius: 50rem; border-bottom-right-radius: 50rem;"
                                   placeholder="Tìm kiếm sản phẩm..." />
                        </div>
                    </div>
                    @{
                        var catItems = ViewBag.CategoriesList as List<MVC17.ViewModels.DropdownItemVM> ?? new List<MVC17.ViewModels.DropdownItemVM>();
                        var supItems = ViewBag.SuppliersList as List<MVC17.ViewModels.DropdownItemVM> ?? new List<MVC17.ViewModels.DropdownItemVM>();
                    }
                    
                    @await Component.InvokeAsync("FilterDropdown", new MVC17.ViewModels.FilterDropdownVM
                    {
                        Name = "categoryId",
                        IconClass = "fas fa-list-ul",
                        DefaultText = "-- Tất cả danh mục --",
                        CurrentValue = (ViewData["CurrentCategory"] ?? 0).ToString(),
                        Items = catItems,
                        ShowBadge = true
                    })

                    @await Component.InvokeAsync("FilterDropdown", new MVC17.ViewModels.FilterDropdownVM
                    {
                        Name = "supplierId",
                        IconClass = "fas fa-building",
                        DefaultText = "-- Tất cả nhà cung cấp --",
                        CurrentValue = (ViewData["CurrentSupplier"] ?? 0).ToString(),
                        Items = supItems,
                        ShowBadge = true
                    })
                    @{
                        var orderTypes = ViewBag.OrderTypes as IEnumerable<SelectListItem>;
                        var orderItems = orderTypes?.Select(o => new MVC17.ViewModels.DropdownItemVM { Value = o.Value, Text = o.Text }).ToList() ?? new List<MVC17.ViewModels.DropdownItemVM>();
                    }
                    @await Component.InvokeAsync("FilterDropdown", new MVC17.ViewModels.FilterDropdownVM
                    {
                        Name = "orderBy",
                        IconClass = "fas fa-sort-amount-down",
                        DefaultText = "-- Sắp xếp theo --",
                        CurrentValue = (ViewData["CurrentOrder"] ?? "").ToString(),
                        Items = orderItems,
                        ShowBadge = false
                    })
                </div>
            </form>
        </div>
    </div>

    <div id="product-list-container">
        <partial name="_AdminProductListPartial" model="Model" view-data="ViewData" />
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="productModalLabel">Sản phẩm</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="productModalContent">
                <!-- Content will be loaded here via AJAX -->
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/product-admin-index.js" asp-append-version="true"></script>
}
