@model IEnumerable<MVC17.ViewModels.ProductVM>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int totalPages = (int)(ViewData["TotalPages"] ?? 1);
    int activePage = (int)(ViewData["ActivePage"] ?? 1);
    int indexPage = 1;
}

<h1>Index</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group mb-2">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Nhập tên sản phẩm..."
               onchange="this.form.submit()" />
    </div>

    <div class="row mb-3">
        <div class="col">
            <select class="form-select"
                    name="categoryId"
                    asp-items="ViewBag.Categories"
                    onchange="this.form.submit()">
                <option value="0">-- Tất cả loại --</option>
            </select>
        </div>

        <div class="col">
            <select class="form-select"
                    name="supplierId"
                    asp-items="ViewBag.Suppliers"
                    onchange="this.form.submit()">
                <option value="0">-- Tất cả NCC --</option>
            </select>
        </div>

        <div class="col">
            <select class="form-select"
                    name="orderBy"
                    asp-items="ViewBag.OrderTypes"
                    onchange="this.form.submit()">
                <option value="">-- Sắp xếp --</option>
            </select>
        </div>
    </div>
</form>

@await Html.PartialAsync("_ProductGrid", Model)

@await Component.InvokeAsync("Pagination", new { active = activePage, index = indexPage, total = totalPages })
