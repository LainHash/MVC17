@model List<MVC17.ViewModels.ProductVM>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var catItems = ViewBag.CategoriesList as List<MVC17.ViewModels.DropdownItemVM> ?? new List<MVC17.ViewModels.DropdownItemVM>();
    var supItems = ViewBag.SuppliersList as List<MVC17.ViewModels.DropdownItemVM> ?? new List<MVC17.ViewModels.DropdownItemVM>();

    var orderTypes = ViewBag.OrderTypes as IEnumerable<SelectListItem>;
    var orderItems = orderTypes?.Select(o => new MVC17.ViewModels.DropdownItemVM { Value = o.Value, Text = o.Text }).ToList() ?? new List<MVC17.ViewModels.DropdownItemVM>();
}

<div class="card shadow-sm mb-4 border-0"
     style="background: linear-gradient(to right, #f8f9fa, #ffffff);">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" id="filter-form">
            <div class="row g-3 align-items-center">
                <div class="col-12 col-md-3">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0 text-muted"
                              style="border-top-left-radius: 50rem; border-bottom-left-radius: 50rem;">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text"
                               name="filterString"
                               value="@ViewData["CurrentFilter"]"
                               class="form-control border-start-0 ps-0 shadow-none"
                               style="border-top-right-radius: 50rem; border-bottom-right-radius: 50rem;"
                               placeholder="Tìm kiếm sản phẩm..." />
                    </div>
                </div>

                @await Component.InvokeAsync("FilterDropdown", new MVC17.ViewModels.FilterDropdownVM
                {
                    Name = "categoryId",
                    IconClass = "fas fa-list-ul",
                    DefaultText = "-- Tất cả danh mục --",
                    CurrentValue = (ViewData["CurrentCategory"] ?? 0).ToString(),
                    Items = catItems,
                    ShowBadge = true
                })

                @await Component.InvokeAsync("FilterDropdown", new MVC17.ViewModels.FilterDropdownVM
                {
                    Name = "supplierId",
                    IconClass = "fas fa-building",
                    DefaultText = "-- Tất cả nhà cung cấp --",
                    CurrentValue = (ViewData["CurrentSupplier"] ?? 0).ToString(),
                    Items = supItems,
                    ShowBadge = true
                })

                @await Component.InvokeAsync("FilterDropdown", new MVC17.ViewModels.FilterDropdownVM
                {
                    Name = "orderBy",
                    IconClass = "fas fa-sort-amount-down",
                    DefaultText = "-- Sắp xếp theo --",
                    CurrentValue = (ViewData["CurrentOrder"] ?? "").ToString(),
                    Items = orderItems,
                    ShowBadge = false
                })
            </div>
        </form>
    </div>
</div>

<div id="product-list-container">
    <partial name="_ProductListPartial" model="Model" view-data="ViewData" />
</div>

@section Scripts {
    <script src="~/js/product-index.js" asp-append-version="true"></script>
}
