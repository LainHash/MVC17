@model MVC17.ViewModels.ProductVM

@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    ViewData["Title"] = "Xóa Sản phẩm";
    Layout = isAjax ? null : "~/Views/Shared/_Layout.cshtml";
}

@if (!isAjax)
{
    @Html.Raw("<div class=\"container-fluid py-4\">")
    <h2 class="mb-4 fw-bold text-dark"><i class="fas fa-trash-alt me-2 text-danger"></i>Xóa Sản phẩm</h2>
    @Html.Raw("<div class=\"card shadow-sm border-0 rounded-3 mb-4\">")
    @Html.Raw("<div class=\"card-body p-4\">")
}

<div class="delete-form-container">
    <div class="alert alert-danger d-flex align-items-center mb-4 rounded-3 border-0 shadow-sm" role="alert">
        <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
        <div>
            <h5 class="alert-heading fw-bold mb-1">Cảnh báo xóa dữ liệu!</h5>
            <p class="mb-0">Bạn có chắc chắn muốn xóa sản phẩm <strong>@Model.ProductName</strong> không? Hành động này không thể hoàn tác.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 text-center mb-3 mb-md-0">
            <img src="@(Model.ImageUrl ?? Url.Content("~/img/NotFoundImage.png"))" 
                 alt="@Model.ProductName" 
                 class="img-fluid rounded-3 border p-1 shadow-sm" 
                 style="max-height: 200px; object-fit: contain;" />
        </div>
        <div class="col-md-8">
            <table class="table table-borderless table-sm mb-0">
                <tbody>
                    <tr>
                        <th class="text-secondary w-25">@Html.DisplayNameFor(model => model.ProductUuid)</th>
                        <td class="fw-medium">@Html.DisplayFor(model => model.ProductUuid)</td>
                    </tr>
                    <tr>
                        <th class="text-secondary">@Html.DisplayNameFor(model => model.ProductName)</th>
                        <td class="fw-bold fs-5 text-dark">@Html.DisplayFor(model => model.ProductName)</td>
                    </tr>
                    <tr>
                        <th class="text-secondary">@Html.DisplayNameFor(model => model.CategoryName)</th>
                        <td><span class="badge bg-secondary">@Html.DisplayFor(model => model.CategoryName)</span></td>
                    </tr>
                    <tr>
                        <th class="text-secondary">@Html.DisplayNameFor(model => model.CompanyName)</th>
                        <td>@Html.DisplayFor(model => model.CompanyName)</td>
                    </tr>
                    <tr>
                        <th class="text-secondary">Mô tả</th>
                        <td><small class="text-muted">@(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)</small></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
        <input type="hidden" asp-for="ProductId" />
        
        @if (isAjax)
        {
            <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
        }
        else
        {
            <a asp-action="Index" class="btn btn-light border">Hủy</a>
        }
        
        <button type="submit" class="btn btn-danger px-4 fw-bold">
            <i class="fas fa-trash-alt me-1"></i> Xác nhận Xóa
        </button>
    </form>
</div>

@if (!isAjax)
{
    @Html.Raw("</div></div></div>")
}
