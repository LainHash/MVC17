@model IEnumerable<MVC17.Models.VwInvoice>
@using MVC17.Helpers.Constants.Orders

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark"><i class="fas fa-file-invoice-dollar me-2 text-primary"></i> Danh sách Đơn hàng</h2>
            <p class="text-muted mb-0">Quản lý và theo dõi tất cả hóa đơn trong hệ thống</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4 fw-semibold border-bottom-0">Mã ĐH / KH</th>
                            <th class="fw-semibold border-bottom-0">Mã NV</th>
                            <th class="fw-semibold border-bottom-0">Ngày đặt</th>
                            <th class="fw-semibold border-bottom-0">Ngày giao (DK/TT)</th>
                            <th class="fw-semibold border-bottom-0">Trạng thái</th>
                            <th class="fw-semibold border-bottom-0 text-end">Tổng tiền</th>
                            <th class="fw-semibold border-bottom-0">Ghi chú</th>
                            <th class="pe-4 fw-semibold border-bottom-0 text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark">#@item.InvoiceId</span>
                                        <span class="text-muted small">KH: @item.CustomerCode</span>
                                    </div>
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.EmployeeCode))
                                    {
                                        <span class="text-muted fst-italic small">Chưa xác nhận</span>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold text-dark">@item.EmployeeCode</span>
                                    }
                                </td>
                                <td>
                                    <span class="d-block"><i class="far fa-calendar-alt me-1 text-muted"></i>@item.OrderedDate.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td>
                                    <div class="d-flex flex-column small">
                                        <span class="text-muted" title="Ngày yêu cầu">
                                            <i class="fas fa-truck-loading me-1"></i>@item.RequiredDate.AddDays(-1).ToString("dd/MM/yyyy") - @item.RequiredDate.AddDays(1).ToString("dd/MM/yyyy")
                                        </span>
                                        <span class="@(item.ShippedDate.HasValue ? "text-success" : "text-warning") mt-1" title="Ngày giao thực tế">
                                            <i class="fas fa-check-circle me-1"></i>@(item.ShippedDate?.ToString("dd/MM/yyyy") ?? "Chưa giao")
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge @InvoiceStatuses.GetStatusStyle(item.Status) px-3 py-2 rounded-pill">
                                        @InvoiceStatuses.GetStatusVi(item.Status)
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold text-danger">@String.Format("{0:N0} đ", item.TotalAmount)</span>
                                </td>
                                <td>
                                    <span class="text-truncate d-inline-block text-muted" style="max-width: 150px;" title="@item.Note">
                                        @(string.IsNullOrEmpty(item.Note) ? "-" : item.Note)
                                    </span>
                                </td>
                                <td class="pe-4 text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.InvoiceId" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                            <i class="fas fa-eye me-1"></i> Chi tiết
                                        </a>
                                        @if (string.IsNullOrEmpty(item.EmployeeCode))
                                        {
                                            <a asp-action="Confirm" asp-route-id="@item.InvoiceId" class="btn btn-sm btn-outline-success" title="Xác nhận đơn hàng">
                                                <i class="fas fa-check me-1"></i> Xác nhận
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="fas fa-box-open fa-3x mb-3 text-light"></i>
                                    <p class="mb-0">Chưa có đơn hàng nào trong hệ thống.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">Hiển thị tổng số <span class="fw-bold">@Model.Count()</span> đơn hàng</small>
            </div>
        </div>
    </div>
</div>
