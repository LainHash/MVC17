@model MVC17.DTOs.Orders.CheckoutDTO

@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-4">
    <h2>Thanh toán</h2>
    <hr />

    <form asp-controller="Order" asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IsBuyMany" />
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="Quantity" />

        <div class="row">
            <div class="col-md-7">
                <div class="card mb-4">
                    <div class="card-header">
                        <h4>Thông tin giao hàng</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" required />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Country" class="form-label">Quốc gia</label>
                            <input asp-for="Country" class="form-control" required />
                            <span asp-validation-for="Country" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="City" class="form-label">Tỉnh/Thành phố</label>
                            <input asp-for="City" class="form-control" required />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Địa chỉ</label>
                            <textarea asp-for="Address" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card">
                    <div class="card-header">
                        <h4>Đơn hàng của bạn</h4>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in Model.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between lh-sm">
                                    <div>
                                        <h6 class="my-0">@item.ProductName</h6>
                                        <small class="text-muted">Số lượng: @item.Quantity</small>
                                    </div>
                                    <span class="text-muted">@item.LineTotal.ToString("N0") VNĐ</span>
                                </li>
                            }
                        </ul>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính</span>
                            <strong>@Model.Subtotal.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá sản phẩm</span>
                            <strong>@Model.ProductDiscount.ToString("P2")</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Phí vận chuyển</span>
                            <strong>@Model.ShippingFee.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá vận chuyển</span>
                            <strong>@Model.ShippingDiscount.ToString("P2")</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-3">
                            <span>Tổng cộng</span>
                            <strong class="text-danger fs-5">@Model.TotalAmount.ToString("N0") VNĐ</strong>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            Xác nhận đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @* Thông báo đặt hàng thành công *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-start gap-3 mt-4 p-4 rounded-3 shadow-sm" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor"
                 class="bi bi-check-circle-fill flex-shrink-0 mt-1" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417
                         5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99
                         a.75.75 0 0 0-.01-1.05z" />
            </svg>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-1">✔ Đặt hàng thành công!</h5>
                <p class="mb-3">@TempData["Success"]</p>
                <div class="d-flex gap-2">
                    <a asp-controller="Account" asp-action="OrderHistory" class="btn btn-outline-success btn-sm">
                        Lịch sử đặt hàng
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-sm">
                        Về trang chủ
                    </a>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @* Thông báo lỗi thanh toán (số dư không đủ, v.v.) *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-start gap-3 mt-4 p-4 rounded-3 shadow-sm" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor"
                 class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98
                         1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995
                         l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0
                         1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-1">✖ Thanh toán thất bại</h5>
                <p class="mb-3">@TempData["Error"]</p>
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-danger btn-sm">
                    Quay lại giỏ hàng
                </a>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @* Cảnh báo từ ViewData (ví dụ: giỏ hàng trống) *@
    @if (ViewData["Error"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center gap-2 mt-4" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                 class="bi bi-info-circle-fill flex-shrink-0" viewBox="0 0 16 16">
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533
                         .194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703
                         0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081
                         .082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z" />
            </svg>
            <div>@ViewData["Error"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }
</div>