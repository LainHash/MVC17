@model MVC17.ViewModels.CheckoutVM

@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-4">
    <h2>Thanh toán</h2>
    <hr />

    <form asp-controller="Order" asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IsBuyMany" />
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="Quantity" />

        <div class="row">
            <div class="col-md-7">
                <div class="card mb-4">
                    <div class="card-header">
                        <h4>Thông tin giao hàng</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" required />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Địa chỉ</label>
                            <textarea asp-for="Address" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card">
                    <div class="card-header">
                        <h4>Đơn hàng của bạn</h4>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in Model.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between lh-sm">
                                    <div>
                                        <h6 class="my-0">@item.ProductName</h6>
                                        <small class="text-muted">Số lượng: @item.Quantity</small>
                                    </div>
                                    <span class="text-muted">@item.LineTotal.ToString("N0") VNĐ</span>
                                </li>
                            }
                        </ul>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính</span>
                            <strong>@Model.Subtotal.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá sản phẩm</span>
                            <strong>@Model.ProductDiscount.ToString("P2")</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Phí vận chuyển</span>
                            <strong>@Model.ShippingFee.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá vận chuyển</span>
                            <strong>@Model.ShippingDiscount.ToString("P2")</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-3">
                            <span>Tổng cộng</span>
                            <strong class="text-danger fs-5">@Model.TotalAmount.ToString("N0") VNĐ</strong>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            Xác nhận đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="container mt-5">
    </div>

    <!-- Success Modal -->
    <div class="modal fade" id="successModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-success">

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        Thanh toán thành công
                    </h5>
                </div>

                <div class="modal-body text-center">
                    <h4 class="text-success mb-3">
                        ✔ Đặt hàng thành công
                    </h4>

                    <p>
                        @TempData["Success"]
                    </p>
                </div>

                <div class="modal-footer">
                    <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-success">
                        Về trang chủ
                    </a>
                </div>

            </div>
        </div>
    </div>

    <!-- Error Modal -->
    <div class="modal fade" id="errorModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        Thanh toán thất bại
                    </h5>
                </div>

                <div class="modal-body text-center">
                    <h4 class="text-danger mb-3">
                        ✖ Thanh toán thất bại
                    </h4>

                    <p>
                        @TempData["Error"]
                    </p>
                </div>

                <div class="modal-footer">
                    <a asp-controller="Cart"
                           asp-action="Index"
                           class="btn btn-danger">
                        Quay lại giỏ hàng
                    </a>
                </div>

            </div>
        </div>
    </div>
}


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    window.onload = function () {

    var successMessage = '@TempData["Success"]';
    var errorMessage = '@TempData["Error"]';

    if (successMessage) {
    var successModal = new bootstrap.Modal(document.getElementById('successModal'));
    successModal.show();
    }

    if (errorMessage) {
    var errorModal = new bootstrap.Modal(document.getElementById('errorModal'));
    errorModal.show();
    }
    };
</script>