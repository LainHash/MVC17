@model MVC17.DTOs.Orders.CheckoutDTO

@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-4">
    <h2>Thanh toán</h2>
    <hr />

    <form asp-controller="Order" asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IsBuyMany" />
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="Quantity" />

        <div class="row">
            <div class="col-md-7">
                <div class="card mb-4">
                    <div class="card-header">
                        <h4>Thông tin giao hàng</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" required />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Country" class="form-label">Quốc gia</label>
                            <select class="form-control"
                                    asp-for="Country"
                                    asp-items="ViewBag.Countries"
                                    required>
                                <option value="@Model.Country">@Model.Country</option>
                            </select>
                            <span asp-validation-for="Country" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="City" class="form-label">Tỉnh/Thành phố</label>
                            <select class="form-control"
                                    asp-for="City"
                                    asp-items="ViewBag.Cities"
                                    required>
                                <option value="@Model.City">@Model.City</option>
                            </select>
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Địa chỉ</label>
                            <textarea asp-for="Address" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card">
                    <div class="card-header">
                        <h4>Đơn hàng của bạn</h4>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in Model.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between lh-sm">
                                    <div>
                                        <h6 class="my-0">@item.ProductName</h6>
                                        <small class="text-muted">Số lượng: @item.Quantity</small>
                                    </div>
                                    <span class="text-muted">@item.LineTotal.ToString("N0") VNĐ</span>
                                </li>
                            }
                        </ul>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính</span>
                            <strong>@Model.Subtotal.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá sản phẩm</span>
                            <strong>@Model.ProductDiscount.ToString("P2")</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Phí vận chuyển</span>
                            <strong>@Model.ShippingFee.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá vận chuyển</span>
                            <strong>@Model.ShippingDiscount.ToString("P2")</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-3">
                            <span>Tổng cộng</span>
                            <strong class="text-danger fs-5">@Model.TotalAmount.ToString("N0") VNĐ</strong>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            Xác nhận đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @* Modal Thông báo lỗi *@
    <div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 shadow">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold text-danger" id="errorModalLabel">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Thông báo lỗi
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="fs-5 mb-0" id="errorMessage">
                        @(TempData["Error"] ?? ViewData["Error"] ?? "Đã có lỗi xảy ra trong quá trình xử lý.")
                    </p>
                </div>
                <div class="modal-footer border-top-0 flex-column align-items-stretch w-100 gap-2 pb-3">
                    <button type="button" class="btn btn-lg btn-danger rounded-3" data-bs-dismiss="modal">Ở lại trang</button>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-lg btn-link fs-6 text-decoration-none text-secondary">Quay về danh sách sản phẩm</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            @if (TempData["Error"] != null || ViewData["Error"] != null)
            {
                        <text>
                                    var errorModal = new bootstrap.Modal(document.getElementById('errorModal'));
                                    errorModal.show();
                        </text>
            }
        });
    </script>
}