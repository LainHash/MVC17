@model MVC17.Models.VwInvoice

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body text-center p-5">

                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>

                    <h1 class="fw-bold text-success mb-3">Đặt hàng thành công!</h1>
                    <p class="text-muted fs-5 mb-4">
                        Cảm ơn bạn đã đặt hàng. Đơn hàng của bạn đã được ghi nhận và đang chờ xử lý.
                    </p>

                    <div class="bg-light rounded-4 p-4 text-start mb-4">
                        <h5 class="fw-bold mb-3">Thông tin đơn hàng</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Mã tra cứu:</span>
                            <strong>@Model.InvoiceUuid</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Ngày đặt:</span>
                            <strong>@Model.OrderedDate.ToString("dd/MM/yyyy")</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Trạng thái:</span>
                            <span class="badge bg-warning text-dark px-3 py-2">@Model.Status</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <strong>@Model.Subtotal.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Phí vận chuyển:</span>
                            <strong>@Model.ShippingFee.ToString("N0") VNĐ</strong>
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <span class="fw-bold fs-5">Tổng thanh toán:</span>
                            <strong class="text-danger fs-4">@Model.TotalAmount.ToString("N0") VNĐ</strong>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a asp-controller="Order"
                               asp-action="CheckoutResult"
                               asp-route-id="@Model.InvoiceId"
                               class="btn btn-primary btn-lg px-4">
                            Xem chi tiết đơn hàng
                        </a>

                        <a asp-controller="Account"
                               asp-action="OrderHistory"
                               class="btn btn-outline-success btn-lg px-4">
                            Lịch sử đặt hàng
                        </a>

                        <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-outline-secondary btn-lg px-4">
                            Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
