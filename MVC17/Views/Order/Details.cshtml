@model MVC17.Models.VwInvoice
@using MVC17.Helpers.Constants.Orders

@{
    ViewData["Title"] = "Order Details";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chi tiết đơn hàng #@Model.InvoiceUuid</h2>
        <a asp-action="OrderHistory" asp-controller="Account" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại lịch sử
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Products Table -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 py-2"><i class="fas fa-box-open text-primary me-2"></i>Danh sách sản phẩm</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Tên sản phẩm</th>
                                    <th>Loại sản phẩm</th>
                                    <th>Công ty</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end pe-4">Tổng cộng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.InvoiceDetails != null)
                                {
                                    foreach (var item in ViewBag.InvoiceDetails)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <span class="fw-semibold">@item.ProductName</span>
                                            </td>
                                            <td>@item.CategoryName</td>
                                            <td>@item.CompanyName</td>
                                            <td class="text-end">@String.Format("{0:N0} đ", item.UnitPrice)</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end pe-4 fw-bold text-primary">@String.Format("{0:N0} đ", item.LineTotal)</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Không có sản phẩm nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Note Section -->
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 py-2"><i class="fas fa-sticky-note text-warning me-2"></i>Ghi chú đơn hàng</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-0 text-muted">@Model.Note</p>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <!-- Order Status & Dates -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 py-2"><i class="fas fa-info-circle text-info me-2"></i>Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3 align-items-center">
                        <span class="text-muted">Trạng thái:</span>
                        <span class="badge @InvoiceStatuses.GetStatusStyle(Model.Status) px-3 py-2 rounded-pill">
                            
                            @InvoiceStatuses.GetStatusVi(Model.Status)
                        </span>
                    </div>
                    <hr class="text-muted" />
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Mã KH:</span>
                        <span class="fw-semibold">@Html.DisplayFor(model => model.CustomerCode)</span>
                    </div>
                    <hr class="text-muted" />
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ngày đặt hàng:</span>
                        <span>@(Model.OrderedDate.ToString("dd/MM/yyyy") ?? "-")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ngày yêu cầu:</span>
                        <span>@(Model.RequiredDate.ToString("dd/MM/yyyy") ?? "-")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ngày giao hàng:</span>
                        <span>@(Model.ShippedDate?.ToString("dd/MM/yyyy") ?? "Chưa giao")</span>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 py-2"><i class="fas fa-file-invoice-dollar text-success me-2"></i>Tóm tắt chi phí</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Thành tiền:</span>
                        <span>@String.Format("{0:N0} đ", Model.Subtotal)</span>
                    </div>
                    @if (Model.ProductDiscount > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Giảm giá SP:</span>
                            <span>-@String.Format("{0:N0} đ", Model.ProductDiscount)</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span>@String.Format("{0:N0} đ", Model.ShippingFee)</span>
                    </div>
                    @if (Model.ShippingDiscount > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Giảm phí VC:</span>
                            <span>-@String.Format("{0:N0} đ", Model.ShippingDiscount)</span>
                        </div>
                    }
                    <hr class="text-muted">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-bold">Tổng cộng:</span>
                        <span class="fs-4 fw-bold text-danger">@String.Format("{0:N0} đ", Model.TotalAmount)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
