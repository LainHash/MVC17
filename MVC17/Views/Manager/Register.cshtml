@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng ký - Quản lý";
}
@model MVC17.DTOs.Accounts.Managers.Create.RegisterDTO

<div class="row justify-content-center w-100 m-0 py-5">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom-0 text-center pt-4">
                <h3 class="fw-bold text-dark">Đăng ký - Quản lý</h3>
            </div>

            <div class="card-body px-4 pb-4">
                <form asp-controller="Manager" asp-action="Register" method="post">
                    <div class="row">
                        <!-- Username -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Username" class="form-label">Tên tài khoản</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">Email đăng nhập</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Password -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label">Mật khẩu</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- AvatarImage -->
                    <div class="mb-3">
                        <label asp-for="AvatarImage" class="form-label">Ảnh đại diện (URL)</label>
                        <input asp-for="AvatarImage" class="form-control" placeholder="Nhập link ảnh đại diện (URL)..." />
                        <span asp-validation-for="AvatarImage" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <!-- First Name -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.FirstName" class="form-label">Tên</label>
                            <input asp-for="Profile.FirstName" class="form-control" />
                            <span asp-validation-for="Profile.FirstName" class="text-danger"></span>
                        </div>

                        <!-- Last Name -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.LastName" class="form-label">Họ</label>
                            <input asp-for="Profile.LastName" class="form-control" />
                            <span asp-validation-for="Profile.LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Gender -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giới tính</label>
                            <select asp-for="Profile.Gender" class="form-select">
                                <option value="true">Nam</option>
                                <option value="false">Nữ</option>
                            </select>
                        </div>

                        <!-- Dob -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.Dob" class="form-label">Ngày sinh</label>
                            <input asp-for="Profile.Dob" type="date" class="form-control" />
                            <span asp-validation-for="Profile.Dob" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <!-- City -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.City" class="form-label">Thành phố</label>
                            <select asp-for="Profile.City" class="form-select" asp-items="ViewBag.Cities"></select>
                        </div>

                        <!-- Country -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.Country" class="form-label">Quốc gia</label>
                            <select asp-for="Profile.Country"
                                    class="form-select"
                                    asp-items="ViewBag.Countries">
                            </select>
                        </div>
                    </div>

                    <!-- Address -->
                    <div class="mb-3">
                        <label asp-for="Profile.Address" class="form-label">Địa chỉ</label>
                        <input asp-for="Profile.Address" class="form-control" />
                        <span asp-validation-for="Profile.Address" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <!-- Personal Email -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.Email" class="form-label">Email cá nhân</label>
                            <input asp-for="Profile.Email" class="form-control" />
                            <span asp-validation-for="Profile.Email" class="text-danger"></span>
                        </div>

                        <!-- Phone -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Profile.Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Profile.Phone" class="form-control" />
                            <span asp-validation-for="Profile.Phone" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- CCCD -->
                    <div class="mb-3">
                        <label asp-for="Profile.CitizenIdentityCard" class="form-label">CCCD/CMND</label>
                        <input asp-for="Profile.CitizenIdentityCard" class="form-control" />
                        <span asp-validation-for="Profile.CitizenIdentityCard" class="text-danger"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary">
                            Đăng ký
                        </button>
                    </div>

                </form>
            </div>

            <div class="card-footer bg-white border-top-0 text-center pb-4">
                <small>Đã có tài khoản? <a asp-controller="Manager" asp-action="Login">Đăng nhập</a></small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
