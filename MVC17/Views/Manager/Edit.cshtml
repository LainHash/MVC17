@model MVC17.DTOs.Accounts.Managers.Update.ManagerProfileEditDTO

@{
    ViewData["Title"] = "Chỉnh Sửa Hồ Sơ Nhân Viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark">
                <i class="fas fa-edit me-2 text-primary"></i>Chỉnh Sửa Hồ Sơ
            </h2>
            <p class="text-muted mb-0">Cập nhật thông tin cá nhân của bạn</p>
        </div>
        <a asp-action="Profile" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay Lại
        </a>
    </div>

    <form method="post" asp-action="Edit">
        <div class="row">
            <div class="col-lg-8">
                <!-- Account Information -->
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 py-2">
                            <i class="fas fa-lock text-primary me-2"></i>Thông Tin Tài Khoản
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="EmployeeCode" class="form-label">Mã Nhân Viên</label>
                                <input type="text" class="form-control form-control-lg" asp-for="EmployeeCode" disabled />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Username" class="form-label">Tên Đăng Nhập</label>
                                <input type="text" class="form-control form-control-lg" asp-for="Username" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label">Email Đăng Nhập</label>
                                <input type="email" class="form-control form-control-lg" asp-for="Email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <label asp-for="CompanyEmail" class="form-label">Email Công Ty</label>
                                <input type="email" class="form-control form-control-lg" asp-for="CompanyEmail" />
                                <span asp-validation-for="CompanyEmail" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-12">
                                <label asp-for="AvatarImage" class="form-label">Ảnh Đại Diện (URL)</label>
                                <input type="text" class="form-control form-control-lg" asp-for="AvatarImage" placeholder="Nhập link ảnh đại diện (URL)..." />
                                <span asp-validation-for="AvatarImage" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Personal Information -->
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 py-2">
                            <i class="fas fa-user-circle text-primary me-2"></i>Thông Tin Cá Nhân
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label">Tên</label>
                                <input type="text" class="form-control form-control-lg" asp-for="FirstName" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label">Họ</label>
                                <input type="text" class="form-control form-control-lg" asp-for="LastName" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label">Giới Tính</label>
                                <select asp-for="Gender" asp-items="ViewBag.Genders" class="form-select form-select-lg">
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Dob" class="form-label">Ngày Sinh</label>
                                <input type="date" class="form-control form-control-lg" asp-for="Dob" />
                                <span asp-validation-for="Dob" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label">Số Điện Thoại</label>
                                <input type="tel" class="form-control form-control-lg" asp-for="Phone" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CitizenIdentityCard" class="form-label">Số CMND/CCCD</label>
                                <input type="text" class="form-control form-control-lg" asp-for="CitizenIdentityCard" />
                                <span asp-validation-for="CitizenIdentityCard" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 py-2">
                            <i class="fas fa-map-marker-alt text-primary me-2"></i>Thông Tin Liên Hệ
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Country" class="form-label">Quốc Gia</label>
                                <select asp-for="Country" asp-items="ViewBag.Countries" class="form-select form-select-lg">
                                    <option value="">-- Chọn Quốc Gia --</option>
                                </select>
                                <span asp-validation-for="Country" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="City" class="form-label">Tỉnh/Thành Phố</label>
                                <select asp-for="City" asp-items="ViewBag.Cities" class="form-select form-select-lg">
                                    <option value="">-- Chọn Tỉnh/Thành Phố --</option>
                                </select>
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <label asp-for="Address" class="form-label">Địa Chỉ</label>
                                <input type="text" class="form-control form-control-lg" asp-for="Address" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons Sidebar -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 py-2">
                            <i class="fas fa-cog text-primary me-2"></i>Hành Động
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2 mb-3">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-save me-2"></i>Lưu Thay Đổi
                            </button>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-action="Profile" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Hủy
                            </a>
                        </div>

                        <hr />

                        <a asp-action="ChangePassword" class="btn btn-warning w-100">
                            <i class="fas fa-key me-2"></i>Đổi Mật Khẩu
                        </a>

                        <!-- Info Box -->
                        <div class="alert alert-info mt-3" role="alert">
                            <i class="fas fa-info-circle me-2"></i>
                            <small><strong>Lưu ý:</strong> Tất cả các trường được đánh dấu <span class="text-danger">*</span> là bắt buộc.</small>
                        </div>

                        <div class="alert alert-warning mt-2" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <small><strong>Cảnh báo:</strong> Nếu bạn thay đổi email, bạn có thể cần đăng nhập lại.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
