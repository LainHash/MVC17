@model MVC17.Models.VwCustomerProfile

@{
    ViewData["Title"] = "Hồ Sơ Khách Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark">
                <i class="fas fa-user-circle me-2 text-primary"></i>Hồ Sơ Khách hàng
            </h2>
            <p class="text-muted mb-0">Xem thông tin cá nhân của khách hàng</p>
        </div>
        <div class="btn-group">
            @* <a asp-action="EditManager" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Chỉnh sửa
            </a>
            <a asp-action="ChangePasswordManager" class="btn btn-warning">
                <i class="fas fa-key me-2"></i>Đổi mật khẩu
            </a> *@
        </div>
    </div>

    <div class="row">
        <!-- Profile Info -->
        <div class="col-lg-8">
            <!-- Personal Information Card -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 py-2">
                        <i class="fas fa-id-card text-primary me-2"></i>Thông Tin Cá Nhân
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Mã Khách hàng</label>
                            <p class="fw-bold text-dark">@Model.CustomerCode</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Email Đăng nhập</label>
                            <p class="fw-bold text-dark">@Model.AccountEmail</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Tên</label>
                            <p class="fw-bold text-dark">@Model.FirstName</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Họ</label>
                            <p class="fw-bold text-dark">@Model.LastName</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Giới Tính</label>
                            <p class="fw-bold text-dark">
                                @(Model.Gender ? "Nam" : "Nữ")
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Ngày Sinh</label>
                            <p class="fw-bold text-dark">
                                    @Model.Dob.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Số Điện Thoại</label>
                            <p class="fw-bold text-dark">
                                <i class="fas fa-phone me-1 text-muted"></i>@Model.Phone
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Email Cá Nhân</label>
                            <p class="fw-bold text-dark">
                                <i class="fas fa-envelope me-1 text-muted"></i>@Model.PersonalEmail
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Quốc Gia</label>
                            <p class="fw-bold text-dark">@Model.Country</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Tỉnh/Thành Phố</label>
                            <p class="fw-bold text-dark">@Model.City</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <label class="form-label text-muted small">Địa Chỉ</label>
                            <p class="fw-bold text-dark">@Model.Address</p>
                        </div>
                    </div>

                    <div class="row pt-3">
                        <div class="col-12">
                            <label class="form-label text-muted small">Số CMND/CCCD</label>
                            <p class="fw-bold text-dark">@Model.CitizenIdentityCard</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Information Sidebar -->
        <div class="col-lg-4">
            <!-- Account Card -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 py-2">
                        <i class="fas fa-lock text-warning me-2"></i>Tài Khoản
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        @if (ViewBag.AvatarImage != null && !string.IsNullOrEmpty(ViewBag.AvatarImage as string))
                        {
                            <img src="@ViewBag.AvatarImage" alt="Avatar" class="rounded-circle shadow-sm border" style="width: 100px; height: 100px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle shadow-sm border bg-light d-inline-flex justify-content-center align-items-center text-secondary" style="width: 100px; height: 100px;">
                                <i class="fas fa-user fa-3x"></i>
                            </div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Tên Đăng Nhập</label>
                        <p class="fw-bold text-dark">@Model.Username</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small">Email Đăng Nhập</label>
                        <p class="fw-bold text-dark">
                            <i class="fas fa-envelope me-1 text-muted"></i>
                            @Model.AccountEmail
                        </p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small">Số Dư Tài Khoản</label>
                        <p class="fw-bold text-primary fs-5">
                            @String.Format("{0:N0} đ", Model.Balance)
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
