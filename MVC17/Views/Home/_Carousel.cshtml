<!-- Carousel Start -->
<div class="header-carousel mb-5">
    <div id="carouselId" class="carousel slide" data-bs-ride="carousel" data-bs-interval="false">
        <ol class="carousel-indicators">
            <li data-bs-target="#carouselId" data-bs-slide-to="0" class="active" aria-current="true" aria-label="First slide"></li>
            <li data-bs-target="#carouselId" data-bs-slide-to="1" aria-label="Second slide"></li>
        </ol>
        <div class="carousel-inner" role="listbox">
            <div class="carousel-item active">
                <img src="https://cdn.mos.cms.futurecdn.net/N6NZmRntLssYXyATWwYd9V-1200-80.jpg.webp" class="img-fluid w-100" alt="First slide" />
                <div class="carousel-caption">
                    <div class="container py-4">
                        <div class="row g-5">
                            <div class="col-lg-6 fadeInLeft animated" data-animation="fadeInLeft" data-delay="1s" style="animation-delay: 1s;">
                                <div class="bg-secondary rounded p-5 h-100 d-flex flex-column justify-content-center">
                                    <h5 class="text-uppercase text-white-50 mb-3">Chào mừng bạn</h5>

                                    <h1 class="display-4 text-white fw-bold mb-4">
                                        Bắt đầu hành trình của bạn với sự tiện nghi, an toàn và khác biệt
                                    </h1>

                                    <p class="text-white fs-5 mb-0">
                                        <button type="button" class="btn btn-primary btn-lg px-4 gap-3">
                                            <a asp-controller="Product"
                                               asp-action="Index"
                                               class="text-white">Sản phẩm</a>
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-lg px-4">
                                            <a asp-controller="Account"
                                               asp-action="Register"
                                               style="color:red">Đăng ký</a>
                                        </button>
                                    </p>
                                </div>
                            </div>
                            <div class="col-lg-6 d-none d-lg-flex fadeInRight animated" data-animation="fadeInRight" data-delay="1s" style="animation-delay: 1s;">
                                <div class="text-start">
                                    <h1 class="display-5 text-white">Get 15% off your rental Plan your trip now</h1>
                                    <p>Treat yourself in USA</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://cdn.fstoppers.com/styles/large_16_9/s3/lead/2025/12/img-15-inch-macbook-air-smart-choice-photography.jpeg.webp?itok=CTsg2hRu" class="img-fluid w-100" alt="First slide" />
                <div class="carousel-caption">
                    <div class="container py-4">
                        <div class="row g-5">
                            <div class="col-lg-6 fadeInLeft animated" data-animation="fadeInLeft" data-delay="1s" style="animation-delay: 1s;">
                                <div class="bg-secondary rounded p-5 h-100 d-flex flex-column justify-content-center">
                                    <h5 class="text-uppercase text-white-50 mb-3">Chào mừng bạn</h5>

                                    <h1 class="display-4 text-white fw-bold mb-4">
                                        Bắt đầu hành trình của bạn với sự tiện nghi, an toàn và khác biệt
                                    </h1>

                                    <p class="text-white fs-5 mb-0">
                                        Đăng ký ngay hôm nay để trải nghiệm dịch vụ nhanh chóng, thuận tiện và cá nhân hóa, giúp mỗi chuyến đi của bạn trở nên dễ dàng và trọn vẹn hơn.
                                    </p>
                                </div>
                            </div>
                            <div class="col-lg-6 d-none d-lg-flex fadeInRight animated" data-animation="fadeInRight" data-delay="1s" style="animation-delay: 1s;">
                                <div class="text-start">
                                    <h1 class="display-5 text-white">Get 15% off your rental! Choose Your Model </h1>
                                    <p>Treat yourself in USA</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Carousel End -->