{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MyConnectString": "#{SQL_CONNECTION_STRING}#"
  },
  "Jwt": {
    "Key": "#{JWT_SECRET}#",
    "Issuer": "MyApp",
    "Audience": "MyAppUsers"
  },
  "GmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "SenderEmail": "#{GMAIL_SENDER_EMAIL}#",
    "SenderName": "DDH",
    "AppPassword": "#{EMAIL_SMTP_PASSWORD}#"
  }
}
