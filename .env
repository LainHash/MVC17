# ============================================================
# .env.example — Environment variable template
# ============================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# ⚠️  NEVER commit the actual .env file to Git!
# ============================================================

# ── Database ─────────────────────────────────────────────────
# For local docker-compose: use the container name as host
# For production: use the actual DB server host/IP
SQL_CONNECTION_STRING=Data Source=db; Initial Catalog=DBMVC05; Persist Security Info=True; User ID=sa; Password=123456; Trust Server Certificate=True;

# SA password for the SQL Server container (docker-compose only)
SA_PASSWORD=123456

